# OpenRouter credentials and model selection.
# Copy this to .env (which is gitignored) and fill in your key:
#   cp .env.example .env
# Get a key:      https://openrouter.ai/keys
# Browse models:  https://openrouter.ai/models   (use the slug, e.g. "anthropic/claude-3.5-sonnet")

OPENROUTER_API_KEY=

# The model to call. Any OpenRouter slug works; override per-call with --model.
# Examples: openai/gpt-4o-mini · anthropic/claude-3.5-sonnet · google/gemini-2.0-flash-001
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional. Only change the base URL for a proxy/self-host.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution headers (used for OpenRouter app rankings).
# OPENROUTER_APP_URL=https://ryan258.github.io/exemplary-examples/
# OPENROUTER_APP_NAME=Exemplary Examples
